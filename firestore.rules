rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: matches
    // Fields:
    //   - player1: string (required)
    //   - player2: string (required)
    //   - score1: number (required)
    //   - score2: number (required)
    //   - type: string (required, enum)
    //   - createdAt: timestamp (required)
    //   - authorUid: string (required)
    //
    // Collection: players
    // Fields:
    //   - name: string (required)
    //   - rank: number (required)
    //   - winRate: number (required)
    //   - matches: number (required)
    //   - points: number (required)
    //   - avatar: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "shaheerkhawar287@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidMatch(data) {
      return data.player1 is string && data.player1.size() > 0 && data.player1.size() < 100 &&
             data.player2 is string && data.player2.size() > 0 && data.player2.size() < 100 &&
             data.score1 is number && data.score1 >= 0 &&
             data.score2 is number && data.score2 >= 0 &&
             data.type in ['League Match', 'Quarter-Finals', 'Semi-Finals', 'Finals', 'Friendly'] &&
             data.createdAt is timestamp &&
             data.authorUid == request.auth.uid;
    }

    function isValidPlayer(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.wins is number && data.wins >= 0 &&
             data.losses is number && data.losses >= 0 &&
             data.points is number && data.points >= 0 &&
             data.matches is number && data.matches >= 0 &&
             data.winRate is number && data.winRate >= 0 && data.winRate <= 100;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================
    match /matches/{matchId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && isValidMatch(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /players/{playerId} {
      allow read: if true; // Publicly readable
      allow create, update: if isAuthenticated() && isValidPlayer(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
